{
	"name": "ultimate-ai-connector-webllm",
	"version": "1.1.0",
	"private": true,
	"license": "GPL-2.0-or-later",
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"postbuild": "npm run archive",
		"archive": "composer archive --file=$npm_package_name --format=zip",
		"postarchive": "rm -rf $npm_package_name && unzip -q $npm_package_name.zip -d $npm_package_name && rm $npm_package_name.zip && zip -qr $npm_package_name.zip $npm_package_name && rm -rf $npm_package_name"
	},
	"dependencies": {
		"@mlc-ai/web-llm": "^0.2.79"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.2.0"
	}
}
